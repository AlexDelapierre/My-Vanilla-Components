            </svg>
            {{ card.birthday ? card.birthday|date('d/m/Y') : 'Date inconnue' }}
        </span>
    </p>
    
    <hr class="my-2 border-dashed">
    
    <p class="card-text">
        <span>
            {# SVG Genre #}
            <svg xmlns="http://www.w3.org/2000/svg" height="1em" viewBox="0 0 24 24" width="1em" style="margin-right: 5px; vertical-align: middle;">
