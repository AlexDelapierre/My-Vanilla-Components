<div class="card h-100 cCarousel-item">
  {# Image : Route app_file_get du controleur FilesController #}
  <img src="{{ card.picture ? path('app_file_get', {id: card.picture.id}) : asset('build/themes/basetheme/images/default.jpeg') }}" 
     class="card-img-top" 
     alt="{{ card.name }}">
  
  <div class="card-body text-center">
    <div class="text-center">
        {# Espèce : Utilise le __toString de l'objet AnimalSpecies ou la propriété name #}
        <p class="card-category">{{ card.specie|default('Non renseigné') }}</p>
    </div>
    
    <h3 class="card-title">{{ card.name }}</h3>
    
    <p class="card-text d-flex" style="justify-content: center;">
        <span class="me-3">
            {# SVG Race #}
